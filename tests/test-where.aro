(* Tests for lowbar.matching qualifier *)

(wherefiltersvia-property: Lowbar Filter Test) {
    Create the <users> with [
        { name: "Alice", role: "admin" },
        { name: "Bob", role: "user" },
        { name: "Eve", role: "admin" }
    ].
    Compute the <result: lowbar.matching> from the <users> with { role: "admin" }.
    Compute the <count: lowbar.size> from the <result>.
    Then the <count> with 2.
    Compute the <names: lowbar.pluck> from the <result> with { field: "name" }.
    Then the <names> with ["Alice", "Eve"].
}

(wheremultiple-properties: Lowbar Filter Test) {
    Create the <users> with [
        { name: "Alice", role: "admin", active: true },
        { name: "Bob", role: "user", active: true },
        { name: "Eve", role: "admin", active: false }
    ].
    Compute the <result: lowbar.matching> from the <users> with { role: "admin", active: true }.
    Compute the <count: lowbar.size> from the <result>.
    Then the <count> with 1.
    Compute the <names: lowbar.pluck> from the <result> with { field: "name" }.
    Then the <names> with ["Alice"].
}

(whereno-match-returns-blank: Lowbar Filter Test) {
    Create the <users> with [
        { name: "Alice", role: "admin" },
        { name: "Bob", role: "user" }
    ].
    Compute the <result: lowbar.matching> from the <users> with { role: "guest" }.
    Compute the <count: lowbar.size> from the <result>.
    Then the <count> with 0.
}
