(* Tests for lowbar.reverse qualifier *)

(reverse-list: Lowbar Reverse Test) {
    Create the <items> with [1, 2, 3, 4, 5].
    Compute the <result: lowbar.reverse> from the <items>.
    Then the <result> with [5, 4, 3, 2, 1].
}

(reverse-string: Lowbar Reverse Test) {
    Compute the <result: lowbar.reverse> from "ARO".
    Then the <result> with "ORA".
}

(reverse-single-element: Lowbar Reverse Test) {
    Create the <items> with [42].
    Compute the <result: lowbar.reverse> from the <items>.
    Then the <result> with [42].
}
