(* Tests for lowbar.extend qualifier *)

(extend-mergesand-overwrites: Lowbar Extend Test) {
    Create the <config> with { host: "localhost", port: 8080 }.
    Compute the <result: lowbar.extend> from the <config> with { port: 9090, debug: true }.
    Compute the <host: lowbar.get> from the <result> with { path: "host" }.
    Then the <host> with "localhost".
    Compute the <port: lowbar.get> from the <result> with { path: "port" }.
    Then the <port> with 9090.
    Compute the <debug: lowbar.get> from the <result> with { path: "debug" }.
    Then the <debug> with 1.
}
