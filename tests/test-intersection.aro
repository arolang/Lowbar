(* Tests for lowbar.intersection qualifier *)

(intersection-finds-common: Lowbar Intersection Test) {
    Create the <a> with [1, 2, 3, 4].
    Compute the <result: lowbar.intersection> from the <a> with { other: [3, 4, 5, 6] }.
    Then the <result> with [3, 4].
}

(intersection-no-common: Lowbar Intersection Test) {
    Create the <a> with [1, 2].
    Compute the <result: lowbar.intersection> from the <a> with { other: [3, 4] }.
    Then the <result> with [].
}
