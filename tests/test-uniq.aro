(* Tests for lowbar.uniq qualifier *)

(uniq-removes-duplicates: Lowbar Uniq Test) {
    Create the <items> with [1, 2, 2, 3, 3, 3, 4].
    Compute the <result: lowbar.uniq> from the <items>.
    Then the <result> with [1, 2, 3, 4].
}

(uniq-preserves-order: Lowbar Uniq Test) {
    Create the <items> with [5, 3, 5, 1, 3].
    Compute the <result: lowbar.uniq> from the <items>.
    Then the <result> with [5, 3, 1].
}

(uniq-strings: Lowbar Uniq Test) {
    Create the <items> with ["a", "b", "a", "c", "b"].
    Compute the <result: lowbar.uniq> from the <items>.
    Then the <result> with ["a", "b", "c"].
}
